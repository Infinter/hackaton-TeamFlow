# TeamFlow — variables d'environnement
# Copier ce fichier en `.env.local` (non versionné) et renseigner les valeurs
# depuis le tableau de bord du projet Supabase (Project Settings → API).

# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Clé publique « anon » (sûre côté navigateur — protégée par la RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Clé « service role » — USAGE SERVEUR UNIQUEMENT (seed / admin).
# Contourne la RLS : NE JAMAIS l'exposer côté client ni la committer.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
